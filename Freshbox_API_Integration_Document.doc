  'success': 'Boolean',
  'notifications': 'Array of Objects'
}</pre></td>
        </tr>
    </table>
    
    <table>
        <tr>
            <th width="20%">Endpoint</th>
            <td class="endpoint">/api/notifications/:id/mark-read</td>
        </tr>
        <tr>
            <th>Method</th>
            <td><span class="method patch">PATCH</span></td>
        </tr>
        <tr>
            <th>Description (Details)</th>
            <td>Notification ko read mark karne ke liye.</td>
        </tr>
        <tr>
            <th>Request Payload / Body</th>
            <td><pre>None</pre></td>
        </tr>
        <tr>
            <th>Response Structure</th>
            <td><pre>{
  'success': 'Boolean',
  'message': 'String'
}</pre></td>

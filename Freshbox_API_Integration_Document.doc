  'success': 'Boolean',
  'wallet_balance': 'Number',
  'due_amount': 'Number'
}</pre></td>
        </tr>
    </table>
    
    <table>
        <tr>
            <th width="20%">Endpoint</th>
            <td class="endpoint">/api/wallet/add-funds</td>
        </tr>
        <tr>
            <th>Method</th>
            <td><span class="method post">POST</span></td>
        </tr>
        <tr>
            <th>Description (Details)</th>
            <td>Wallet me funds add karne ke liye (manual process ya via admin/payment).</td>
        </tr>
        <tr>
            <th>Request Payload / Body</th>
            <td><pre>{
  'amount': 'Number (Required)'
}</pre></td>
        </tr>
        <tr>
            <th>Response Structure</th>
            <td><pre>{
  'success': 'Boolean',
  'message': 'String'
}</pre></td>
        </tr>
    </table>
    
    <table>
        <tr>
            <th width="20%">Endpoint</th>
            <td class="endpoint">/api/wallet/wallet/transactions</td>
        </tr>
        <tr>
            <th>Method</th>
            <td><span class="method get">GET</span></td>
        </tr>
        <tr>
            <th>Description (Details)</th>
            <td>Wallet ka transaction history.</td>
        </tr>
        <tr>
            <th>Request Payload / Body</th>
            <td><pre>None</pre></td>
        </tr>
        <tr>
            <th>Response Structure</th>
            <td><pre>{
  'success': 'Boolean',
  'transactions': 'Array of Objects'
}</pre></td>
        </tr>
    </table>
    
    <table>
        <tr>
            <th width="20%">Endpoint</th>
            <td class="endpoint">/api/wallet/admin/tomorrow-summary</td>
        </tr>
        <tr>
            <th>Method</th>
            <td><span class="method get">GET</span></td>
        </tr>
        <tr>
            <th>Description (Details)</th>
            <td>Kal ki kamai / kharcha summary (Admin).</td>
        </tr>
        <tr>
            <th>Request Payload / Body</th>
            <td><pre>None</pre></td>
        </tr>
        <tr>
            <th>Response Structure</th>
            <td><pre>{
  'success': 'Boolean',
  'data': 'Object'
}</pre></td>
        </tr>
    </table>
    
    <table>
        <tr>
            <th width="20%">Endpoint</th>
            <td class="endpoint">/api/wallet/admin/users</td>
        </tr>
        <tr>
            <th>Method</th>
            <td><span class="method get">GET</span></td>
        </tr>
        <tr>
            <th>Description (Details)</th>
            <td>Sabhi users ki list with unka balance (Admin).</td>
        </tr>
        <tr>
            <th>Request Payload / Body</th>
            <td><pre>None</pre></td>
        </tr>
        <tr>
            <th>Response Structure</th>
            <td><pre>{
  'success': 'Boolean',
  'users': 'Array'
}</pre></td>
        </tr>
    </table>
    
    <table>
        <tr>
            <th width="20%">Endpoint</th>
            <td class="endpoint">/api/wallet/admin/user/:id/all-subscriptions</td>
        </tr>
        <tr>
            <th>Method</th>
            <td><span class="method get">GET</span></td>
        </tr>
        <tr>
            <th>Description (Details)</th>
            <td>Kisis user ki saari subscriptions dekhne ke liye (Admin).</td>
        </tr>
        <tr>
            <th>Request Payload / Body</th>
            <td><pre>None</pre></td>
        </tr>
        <tr>
            <th>Response Structure</th>
            <td><pre>{
  'success': 'Boolean',
  'subscriptions': 'Array'
}</pre></td>
        </tr>
    </table>
    
    <table>
        <tr>
            <th width="20%">Endpoint</th>
            <td class="endpoint">/api/wallet/admin/credit/:id/override</td>
        </tr>
        <tr>
            <th>Method</th>
            <td><span class="method patch">PATCH</span></td>
        </tr>
        <tr>
            <th>Description (Details)</th>
            <td>Kisi user ka balance ya due amount override karna (Admin).</td>
        </tr>
        <tr>
            <th>Request Payload / Body</th>
            <td><pre>{
  'wallet_balance': 'Number',
  'due_amount': 'Number'
}</pre></td>
        </tr>
        <tr>
            <th>Response Structure</th>
            <td><pre>{
  'success': 'Boolean',
  'message': 'String'
}</pre></td>
        </tr>
    </table>
    
    <table>
        <tr>
            <th width="20%">Endpoint</th>
            <td class="endpoint">/api/wallet/admin/users/:id/status</td>
        </tr>
        <tr>
            <th>Method</th>
            <td><span class="method patch">PATCH</span></td>
        </tr>
        <tr>
            <th>Description (Details)</th>
            <td>User ko active/inactive karna (Admin).</td>
        </tr>
        <tr>
            <th>Request Payload / Body</th>
            <td><pre>{
  'status': 'String (active/inactive)'
}</pre></td>
        </tr>
        <tr>
            <th>Response Structure</th>
            <td><pre>{
  'success': 'Boolean',
  'message': 'String'
}</pre></td>
        </tr>
    </table>
    <h2>Water Subscription APIs</h2>

    <table>
        <tr>
            <th width="20%">Endpoint</th>
            <td class="endpoint">/api/water/subscribe</td>
        </tr>
        <tr>
            <th>Method</th>
            <td><span class="method post">POST</span></td>
        </tr>
        <tr>
            <th>Description (Details)</th>
            <td>Paani ki bottle / camper ka subscription lene ke liye.</td>
        </tr>
        <tr>
            <th>Request Payload / Body</th>
            <td><pre>{
  'water_type': 'String (e.g. RO/Normal)',
  'container': 'String (e.g. Bottle/Camper)',
  'frequency': 'String (daily/alternate)',
  'address_id': 'Number (Optional)'
}</pre></td>
        </tr>
        <tr>
            <th>Response Structure</th>
            <td><pre>{
  'success': 'Boolean',
  'message': 'String',
  'subscription': 'Object'
}</pre></td>
        </tr>
    </table>
    
    <table>
        <tr>
            <th width="20%">Endpoint</th>
            <td class="endpoint">/api/water/subscriptions</td>
        </tr>
        <tr>
            <th>Method</th>
            <td><span class="method get">GET</span></td>
        </tr>
        <tr>
            <th>Description (Details)</th>
            <td>User ki water subscriptions dekhne ke liye.</td>
        </tr>
        <tr>
            <th>Request Payload / Body</th>
            <td><pre>None</pre></td>
        </tr>
        <tr>
            <th>Response Structure</th>
            <td><pre>{
  'success': 'Boolean',
  'subscriptions': 'Array'
}</pre></td>
        </tr>
    </table>
    
    <table>
        <tr>
            <th width="20%">Endpoint</th>
            <td class="endpoint">/api/water/available-dates</td>
        </tr>
        <tr>
            <th>Method</th>
            <td><span class="method get">GET</span></td>
        </tr>
        <tr>
            <th>Description (Details)</th>
            <td>Paani ki subscription start karne ke liye dates.</td>
        </tr>
        <tr>
            <th>Request Payload / Body</th>
            <td><pre>None</pre></td>
        </tr>
        <tr>
            <th>Response Structure</th>
            <td><pre>{
  'success': 'Boolean',
  'availableDates': 'Array'
}</pre></td>
        </tr>
    </table>
    
    <table>
        <tr>
            <th width="20%">Endpoint</th>
            <td class="endpoint">/api/water/confirm-start-date</td>
        </tr>
        <tr>
            <th>Method</th>
            <td><span class="method post">POST</span></td>
        </tr>
        <tr>
            <th>Description (Details)</th>
            <td>Paani ki subscription ka start date set karna.</td>
        </tr>
        <tr>
            <th>Request Payload / Body</th>
            <td><pre>{
  'subscription_id': 'Number',
  'start_date': 'String (YYYY-MM-DD)'
}</pre></td>
        </tr>
        <tr>
            <th>Response Structure</th>
            <td><pre>{
  'success': 'Boolean',
  'message': 'String'
}</pre></td>
        </tr>
    </table>
    
    <table>
        <tr>
            <th width="20%">Endpoint</th>
            <td class="endpoint">/api/water/:id/pause</td>
        </tr>
        <tr>
            <th>Method</th>
            <td><span class="method patch">PATCH</span></td>
        </tr>
        <tr>
            <th>Description (Details)</th>
            <td>Paani ki subscription rokne ke liye.</td>
        </tr>
        <tr>
            <th>Request Payload / Body</th>
            <td><pre>{
  'pause_days': 'Number',
  'pause_type': 'String (monthly/yearly)',
  'pause_scope': 'String (single/all)'
}</pre></td>
        </tr>
        <tr>
            <th>Response Structure</th>
            <td><pre>{
  'success': 'Boolean',
  'message': 'String'
}</pre></td>
        </tr>
    </table>
    
    <table>
        <tr>
            <th width="20%">Endpoint</th>
            <td class="endpoint">/api/water/:id/restart</td>
        </tr>
        <tr>
            <th>Method</th>
            <td><span class="method patch">PATCH</span></td>
        </tr>
        <tr>
            <th>Description (Details)</th>
            <td>Paani ki subscription wapas start karna.</td>
        </tr>
        <tr>
            <th>Request Payload / Body</th>
            <td><pre>{
  'restart_date': 'String (YYYY-MM-DD)'
}</pre></td>
        </tr>
        <tr>
            <th>Response Structure</th>
            <td><pre>{
  'success': 'Boolean',
  'message': 'String'
}</pre></td>
        </tr>
    </table>
    
    <table>
        <tr>
            <th width="20%">Endpoint</th>
            <td class="endpoint">/api/water/:id/cancel</td>
        </tr>
        <tr>
            <th>Method</th>
            <td><span class="method patch">PATCH</span></td>
        </tr>
        <tr>
            <th>Description (Details)</th>
            <td>Paani ki subscription ko hamesha ke liye cancel karna.</td>
        </tr>
        <tr>
            <th>Request Payload / Body</th>
            <td><pre>None</pre></td>
        </tr>
        <tr>
            <th>Response Structure</th>
            <td><pre>{
  'success': 'Boolean',
  'message': 'String'
}</pre></td>
        </tr>
    </table>
    </body></html>